# LLM Provider Selection (ollama, groq, gemini, or auto)
CONTENT_PROVIDER=auto

# Ollama (local - free, requires ollama installed)
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# Groq (cloud - free tier: 8000 req/day)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b

# Google Gemini (cloud - free tier: 60 req/min)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=flash

# YouTube API
YOUTUBE_CLIENT_SECRETS=client_secrets.json
